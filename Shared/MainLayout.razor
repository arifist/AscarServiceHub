@inherits LayoutComponentBase
@inject NavigationManager Nav

<div class="app-shell">
    <NavMenu />
    <div class="app-content">
        <header class="app-header">
            <button class="sidebar-toggle" onclick="document.getElementById('sidebar').classList.toggle('open')">
                <i class="bi bi-list"></i>
            </button>
            <div class="header-right">
                <div class="header-date d-none d-md-flex">
                    <i class="bi bi-calendar3"></i>
                    @DateTime.Now.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))
                </div>
                <a href="/" class="d-none d-md-flex align-items-center gap-1 text-decoration-none"
                   style="color:var(--text-muted);font-size:13px;padding:6px 10px;border-radius:8px;transition:all 0.2s;"
                   title="Web Sitesine Git">
                    <i class="bi bi-globe" style="font-size:15px"></i>
                </a>
                <a href="/cikis" class="d-flex align-items-center gap-1 text-decoration-none"
                   style="color:var(--text-muted);font-size:13px;padding:6px 10px;border-radius:8px;transition:all 0.2s;"
                   title="Çıkış Yap">
                    <i class="bi bi-box-arrow-right" style="font-size:16px"></i>
                    <span class="d-none d-md-inline">Çıkış</span>
                </a>
                <div class="header-avatar" title="Yönetici">
                    <i class="bi bi-person-fill"></i>
                </div>
            </div>
        </header>
        <main class="app-main">
            @Body
        </main>
        <footer class="app-footer">
            © @DateTime.Now.Year <strong>Ascar Servis</strong> — Oto Sanayi Takip Sistemi
        </footer>
    </div>
</div>
