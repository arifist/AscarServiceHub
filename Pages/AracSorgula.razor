@page "/arac-sorgula"
@layout PublicLayout
@inject JsonDataStore Store

<PageTitle>Araç Durumu Sorgula — Ascar Servis</PageTitle>

<!-- ─── HERO ─────────────────────────────────────────────────── -->
<section style="padding:140px 0 60px; background:linear-gradient(135deg, var(--pub-dark) 0%, #001a40 100%); position:relative; overflow:hidden;">
    <div style="position:absolute; inset:0; background-image:url('https://images.unsplash.com/photo-1489824904134-891ab64532f1?w=1600&q=80&auto=format&fit=crop'); background-size:cover; background-position:center; opacity:0.15;"></div>
    <div class="container-xl" style="position:relative;">
        <div style="max-width:600px; margin:0 auto; text-align:center;">
            <div class="section-tag" style="background:rgba(255,255,255,0.08); color:rgba(255,255,255,0.8); border:1px solid rgba(255,255,255,0.12); display:inline-flex; margin:0 auto 20px;">
                <i class="bi bi-search"></i> Araç Takip
            </div>
            <h1 style="font-size:clamp(32px,5vw,52px); font-weight:900; color:#fff; margin-bottom:16px; line-height:1.1;">
                Aracınız Şu An <span style="color:#60a5fa;">Nerede?</span>
            </h1>
            <p style="font-size:16px; color:rgba(255,255,255,0.6); margin-bottom:40px; line-height:1.7;">
                Plaka numaranızı girerek aracınızın servis durumunu, teknisyen notlarını ve tahmini teslim tarihini öğrenin.
            </p>

            <!-- Search Box -->
            <div style="background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15); border-radius:20px; padding:28px; backdrop-filter:blur(12px);">
                <div style="display:flex; gap:12px; flex-wrap:wrap;">
                    <input @bind="_plateInput" @bind:event="oninput" @onkeydown="HandleKeyDown"
                           style="flex:1; min-width:160px; background:rgba(255,255,255,0.12); border:1.5px solid rgba(255,255,255,0.2); color:#fff; border-radius:12px; padding:14px 18px; font-size:18px; font-weight:800; font-family:monospace; letter-spacing:3px; text-transform:uppercase; outline:none; font-family:'Inter',monospace;"
                           placeholder="34 ABC 123" />
                    <button @onclick="Search" disabled="@_searching"
                            style="background:var(--pub-blue); color:#fff; border:none; border-radius:12px; padding:14px 28px; font-size:15px; font-weight:700; cursor:pointer; white-space:nowrap; display:flex; align-items:center; gap:8px; transition:all 0.2s; opacity:@(_searching ? "0.7" : "1");"
                            onmouseover="this.style.background='var(--pub-blue-dark)';" onmouseout="this.style.background='var(--pub-blue)';">
                        @if (_searching)
                        {
                            <span style="width:16px;height:16px;border:2px solid rgba(255,255,255,0.4);border-top-color:#fff;border-radius:50%;animation:spin 0.7s linear infinite;display:inline-block;"></span>
                        }
                        else
                        {
                            <i class="bi bi-search"></i>
                        }
                        Sorgula
                    </button>
                </div>

                @if (_searched && _vehicle == null)
                {
                    <div style="margin-top:16px; background:rgba(239,68,68,0.15); border:1px solid rgba(239,68,68,0.3); border-radius:10px; padding:12px 16px; color:#fca5a5; font-size:14px; display:flex; align-items:center; gap:8px;">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <strong>@_plateInput.Trim().ToUpperInvariant()</strong>&nbsp;plakalı araç bulunamadı. Plakayı kontrol edip tekrar deneyin.
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<style>
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

<!-- ─── RESULTS ───────────────────────────────────────────────── -->
@if (_vehicle != null)
{
    <section style="padding:60px 0; background:#f8faff;">
        <div class="container-xl">
            <div style="max-width:720px; margin:0 auto;">

                <!-- Vehicle Info Card -->
                <div style="background:#fff; border-radius:20px; padding:28px; border:1px solid var(--pub-border); box-shadow:0 4px 24px rgba(0,0,0,0.06); margin-bottom:20px; display:flex; align-items:center; gap:20px;">
                    <div style="width:60px; height:60px; border-radius:16px; background:var(--pub-blue-light); display:flex; align-items:center; justify-content:center; font-size:28px; flex-shrink:0; color:var(--pub-blue);">
                        <i class="bi bi-car-front-fill"></i>
                    </div>
                    <div style="flex:1;">
                        <div style="font-size:20px; font-weight:800; color:var(--pub-dark2); margin-bottom:6px;">
                            @_vehicle.Brand @_vehicle.Model
                        </div>
                        <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
                            <span style="background:var(--pub-dark2); color:#fff; font-family:monospace; font-size:13px; font-weight:800; padding:4px 12px; border-radius:6px; letter-spacing:1px;">
                                @_vehicle.Plate
                            </span>
                            <span style="font-size:13px; color:var(--pub-gray);">@_vehicle.Year</span>
                            @if (!string.IsNullOrEmpty(_vehicle.Color))
                            { <span style="font-size:13px; color:var(--pub-gray);">• @_vehicle.Color</span> }
                        </div>
                    </div>
                </div>

                @if (_activeRecord != null)
                {
                    <!-- Active Service Status -->
                    <div style="background:#fff; border-radius:20px; border:2px solid var(--pub-blue); box-shadow:0 8px 32px rgba(0,102,204,0.12); margin-bottom:20px; overflow:hidden;">
                        <div style="background:var(--pub-blue-light); padding:16px 28px; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px;">
                            <div style="font-weight:700; font-size:15px; color:var(--pub-blue); display:flex; align-items:center; gap:8px;">
                                <i class="bi bi-activity"></i> Aktif Servis Durumu
                            </div>
                            <span style="font-size:12px; color:var(--pub-gray);">Kayıt No: @_activeRecord.RecordNumber</span>
                        </div>
                        <div style="padding:28px;">
                            <!-- Status Display -->
                            <div style="display:flex; align-items:center; gap:20px; margin-bottom:32px;">
                                <div style="font-size:48px; line-height:1;">@StatusEmoji(_activeRecord.Status)</div>
                                <div>
                                    <div style="font-size:22px; font-weight:800; color:var(--pub-dark2); margin-bottom:4px;">@StatusLabel(_activeRecord.Status)</div>
                                    <div style="font-size:14px; color:var(--pub-gray); line-height:1.6;">@StatusDescription(_activeRecord.Status)</div>
                                </div>
                            </div>

                            <!-- Progress Bar -->
                            <div style="margin-bottom:28px;">
                                <div style="display:flex; justify-content:space-between; margin-bottom:8px;">
                                    <span style="font-size:13px; font-weight:700; color:var(--pub-dark2);">İlerleme</span>
                                    <span style="font-size:13px; color:var(--pub-gray);">Adım @StatusStep(_activeRecord.Status) / 5</span>
                                </div>
                                <div style="height:8px; background:#e5e7eb; border-radius:99px; overflow:hidden;">
                                    <div style="height:100%; width:@(StatusStep(_activeRecord.Status) * 20)%; background:var(--pub-blue); border-radius:99px; transition:width 0.5s ease;"></div>
                                </div>
                                <div style="display:flex; justify-content:space-between; margin-top:8px;">
                                    @foreach (var step in new[] { "Kabul", "İnceleme", "Onarım", "Tamamlandı", "Teslim" })
                                    {
                                        <span style="font-size:10px; color:var(--pub-gray);">@step</span>
                                    }
                                </div>
                            </div>

                            <!-- Info Grid -->
                            <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                                <InfoRow Label="Giriş Tarihi" Value="@_activeRecord.EntryDate.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))" />
                                <InfoRow Label="Serviste" Value="@($"{_activeRecord.DaysInWorkshop} gün")" />
                                @if (_activeRecord.EstimatedDeliveryDate.HasValue)
                                {
                                    var overdue = _activeRecord.EstimatedDeliveryDate.Value.Date < DateTime.Today && _activeRecord.Status != ServiceStatus.Delivered;
                                    <InfoRow Label="Tahmini Teslim" Value="@_activeRecord.EstimatedDeliveryDate.Value.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))" Danger="@overdue" />
                                }
                                @if (!string.IsNullOrEmpty(_activeRecord.AssignedTechnician))
                                {
                                    <InfoRow Label="Teknisyen" Value="@_activeRecord.AssignedTechnician" />
                                }
                            </div>

                            @if (!string.IsNullOrEmpty(_activeRecord.CustomerComplaint))
                            {
                                <div style="margin-top:20px; padding:16px; background:var(--pub-blue-light); border-radius:12px; border-left:3px solid var(--pub-blue);">
                                    <div style="font-size:12px; font-weight:700; color:var(--pub-blue); text-transform:uppercase; letter-spacing:1px; margin-bottom:6px;">Servis Konusu</div>
                                    <div style="font-size:14px; color:var(--pub-dark2); line-height:1.7;">@_activeRecord.CustomerComplaint</div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- History -->
                    @if (_allRecords.Count > 1)
                    {
                        <div style="background:#fff; border-radius:20px; padding:0; border:1px solid var(--pub-border); box-shadow:0 4px 24px rgba(0,0,0,0.06); overflow:hidden; margin-bottom:20px;">
                            <div style="padding:16px 28px; border-bottom:1px solid var(--pub-border);">
                                <span style="font-weight:700; font-size:15px; color:var(--pub-dark2); display:flex; align-items:center; gap:8px;">
                                    <i class="bi bi-clock-history" style="color:var(--pub-blue);"></i> Geçmiş Servisler
                                </span>
                            </div>
                            @foreach (var r in _allRecords.Where(r => r.Id != _activeRecord.Id).Take(5))
                            {
                                <div style="display:flex; align-items:center; justify-content:space-between; padding:14px 28px; border-bottom:1px solid var(--pub-border);">
                                    <div>
                                        <div style="font-weight:700; font-size:13px; color:var(--pub-dark2);">@r.RecordNumber</div>
                                        <div style="font-size:12px; color:var(--pub-gray);">@r.EntryDate.ToString("dd.MM.yyyy")</div>
                                    </div>
                                    @HistoryBadge(r.Status)
                                </div>
                            }
                        </div>
                    }
                }
                else if (_allRecords.Count > 0)
                {
                    <!-- No active service -->
                    <div style="background:#fff; border-radius:20px; padding:40px; border:1px solid var(--pub-border); text-align:center; margin-bottom:20px;">
                        <div style="font-size:56px; margin-bottom:16px;">✅</div>
                        <div style="font-size:18px; font-weight:800; color:var(--pub-dark2); margin-bottom:8px;">Şu An Serviste Değil</div>
                        <p style="font-size:14px; color:var(--pub-gray); margin:0;">@_vehicle.Brand @_vehicle.Model aracınız şu anda serviste bulunmuyor.</p>
                    </div>

                    <div style="background:#fff; border-radius:20px; padding:0; border:1px solid var(--pub-border); overflow:hidden;">
                        <div style="padding:16px 28px; border-bottom:1px solid var(--pub-border);">
                            <span style="font-weight:700; font-size:15px; color:var(--pub-dark2); display:flex; align-items:center; gap:8px;">
                                <i class="bi bi-clock-history" style="color:var(--pub-blue);"></i> Geçmiş Servisler
                            </span>
                        </div>
                        @foreach (var r in _allRecords.Take(5))
                        {
                            <div style="display:flex; align-items:center; justify-content:space-between; padding:14px 28px; border-bottom:1px solid var(--pub-border);">
                                <div>
                                    <div style="font-weight:700; font-size:13px; color:var(--pub-dark2);">@r.RecordNumber</div>
                                    <div style="font-size:12px; color:var(--pub-gray);">@r.EntryDate.ToString("dd.MM.yyyy")</div>
                                </div>
                                @HistoryBadge(r.Status)
                            </div>
                        }
                    </div>
                }

                <!-- Help Footer -->
                <div style="margin-top:28px; text-align:center; padding:20px; background:rgba(0,102,204,0.04); border-radius:12px; border:1px solid rgba(0,102,204,0.12);">
                    <div style="font-size:14px; color:var(--pub-gray); margin-bottom:10px;">Sorularınız için servisimizle iletişime geçin</div>
                    <a href="/iletisim" style="color:var(--pub-blue); font-weight:700; text-decoration:none; font-size:14px; display:inline-flex; align-items:center; gap:6px;">
                        <i class="bi bi-telephone-fill"></i> İletişim Sayfasına Git
                    </a>
                </div>
            </div>
        </div>
    </section>
}
else if (!_searching && !_searched)
{
    <!-- How it works -->
    <section style="padding:80px 0; background:#f8faff;">
        <div class="container-xl">
            <div class="text-center mb-5">
                <h2 style="font-size:24px; font-weight:800; color:var(--pub-dark2); margin-bottom:8px;">Nasıl Çalışır?</h2>
                <p style="color:var(--pub-gray); font-size:14px;">3 adımda aracınızın durumunu öğrenin</p>
            </div>
            <div class="row g-4 justify-content-center" style="max-width:720px; margin:0 auto;">
                @foreach (var (step, i) in _howSteps.Select((s, i) => (s, i)))
                {
                    <div class="col-12 col-sm-4 text-center">
                        <div style="width:56px; height:56px; border-radius:50%; background:var(--pub-blue); color:#fff; display:flex; align-items:center; justify-content:center; font-size:22px; font-weight:900; margin:0 auto 16px;">@(i+1)</div>
                        <div style="font-weight:700; font-size:15px; margin-bottom:6px; color:var(--pub-dark2);">@step.Title</div>
                        <div style="font-size:13px; color:var(--pub-gray); line-height:1.6;">@step.Text</div>
                    </div>
                }
            </div>
        </div>
    </section>
}

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "plaka")]
    public string? Plaka { get; set; }

    private string _plateInput = "";
    private string _lastSearchedPlaka = "";
    private bool _searching = false;
    private bool _searched = false;

    private Vehicle? _vehicle;
    private ServiceRecord? _activeRecord;
    private List<ServiceRecord> _allRecords = new();

    private record HowStep(string Title, string Text);
    private readonly HowStep[] _howSteps =
    [
        new("Plakayı Girin", "Yukarıdaki kutuya aracınızın plakasını girin."),
        new("Sorgula", "\"Sorgula\" butonuna tıklayın veya Enter tuşuna basın."),
        new("Sonuçları Görün", "Aracınızın anlık durumu ve servis detayları görüntülenir."),
    ];

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrWhiteSpace(Plaka) && Plaka != _lastSearchedPlaka)
        {
            _lastSearchedPlaka = Plaka;
            _plateInput = Plaka;
            await Search();
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Search();
    }

    private async Task Search()
    {
        if (string.IsNullOrWhiteSpace(_plateInput)) return;
        _searching = true;
        _searched = false;
        _vehicle = null;
        _activeRecord = null;
        _allRecords = new();

        try
        {
            _vehicle = await Store.FindVehicleByPlateAsync(_plateInput.Trim());
            if (_vehicle != null)
            {
                _allRecords = await Store.GetServiceRecordsByVehicleIdAsync(_vehicle.Id);
                _activeRecord = _allRecords
                    .Where(r => r.Status != ServiceStatus.Delivered)
                    .OrderByDescending(r => r.EntryDate)
                    .FirstOrDefault()
                    ?? _allRecords.OrderByDescending(r => r.EntryDate).FirstOrDefault();
            }
        }
        finally
        {
            _searching = false;
            _searched = true;
        }
    }

    private RenderFragment InfoRow(string Label, string Value, bool Danger = false) =>
        @<div style="background:#f8faff; border-radius:10px; padding:12px 16px;">
            <div style="font-size:11px; font-weight:700; color:var(--pub-gray); text-transform:uppercase; letter-spacing:0.8px; margin-bottom:4px;">@Label</div>
            <div style="font-size:15px; font-weight:700; color:@(Danger ? "#ef4444" : "var(--pub-dark2)");">@Value</div>
        </div>;

    private RenderFragment HistoryBadge(ServiceStatus s) => s switch
    {
        ServiceStatus.Delivered  => @<span style="background:#d1fae5; color:#065f46; font-size:12px; font-weight:700; padding:4px 10px; border-radius:6px;">Teslim Edildi</span>,
        ServiceStatus.Completed  => @<span style="background:#dbeafe; color:#1d4ed8; font-size:12px; font-weight:700; padding:4px 10px; border-radius:6px;">Tamamlandı</span>,
        ServiceStatus.InProgress => @<span style="background:#ede9fe; color:#5b21b6; font-size:12px; font-weight:700; padding:4px 10px; border-radius:6px;">Onarımda</span>,
        _                        => @<span style="background:#fef3c7; color:#92400e; font-size:12px; font-weight:700; padding:4px 10px; border-radius:6px;">Bekliyor</span>,
    };

    private static string StatusEmoji(ServiceStatus s) => s switch
    {
        ServiceStatus.Waiting      => "⏳",
        ServiceStatus.Diagnosing   => "🔍",
        ServiceStatus.InProgress   => "🔧",
        ServiceStatus.WaitingParts => "📦",
        ServiceStatus.Completed    => "✅",
        ServiceStatus.Delivered    => "🎉",
        _                          => "🚗"
    };

    private static string StatusLabel(ServiceStatus s) => s switch
    {
        ServiceStatus.Waiting      => "Kabul Bekleniyor",
        ServiceStatus.Diagnosing   => "İnceleniyor",
        ServiceStatus.InProgress   => "Onarımda",
        ServiceStatus.WaitingParts => "Parça Bekleniyor",
        ServiceStatus.Completed    => "Onarım Tamamlandı",
        ServiceStatus.Delivered    => "Teslim Edildi",
        _                          => "Bilinmiyor"
    };

    private static string StatusDescription(ServiceStatus s) => s switch
    {
        ServiceStatus.Waiting      => "Aracınız servise alınmayı bekliyor.",
        ServiceStatus.Diagnosing   => "Aracınız teknisyenimiz tarafından inceleniyor.",
        ServiceStatus.InProgress   => "Aracınızın onarım çalışmaları devam ediyor.",
        ServiceStatus.WaitingParts => "Aracınız için sipariş edilen parça bekleniyor.",
        ServiceStatus.Completed    => "Onarım tamamlandı. Teslim için hazır.",
        ServiceStatus.Delivered    => "Aracınız teslim edildi.",
        _                          => ""
    };

    private static int StatusStep(ServiceStatus s) => s switch
    {
        ServiceStatus.Waiting      => 1,
        ServiceStatus.Diagnosing   => 2,
        ServiceStatus.InProgress   => 3,
        ServiceStatus.WaitingParts => 3,
        ServiceStatus.Completed    => 4,
        ServiceStatus.Delivered    => 5,
        _                          => 0
    };
}
