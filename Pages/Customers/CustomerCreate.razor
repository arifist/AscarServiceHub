@page "/customers/create"
@inject JsonDataStore Store
@inject NavigationManager Nav

<PageTitle>Yeni Müşteri — Ascar Servis</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Yeni Müşteri Ekle</h1>
        <p class="page-subtitle">Sisteme yeni müşteri kaydı oluşturun</p>
    </div>
    <a href="/customers" class="btn btn-light-sm"><i class="bi bi-arrow-left me-1"></i> Geri</a>
</div>

<div class="row g-3">
    <div class="col-12 col-lg-7">
        <div class="card">
            <div class="card-body">
                <div class="form-section-title"><i class="bi bi-person me-2"></i>Kişisel Bilgiler</div>

                <div class="row g-3 mb-3">
                    <div class="col-sm-6">
                        <label class="form-label">Ad Soyad <span class="text-danger">*</span></label>
                        <input class="form-control" placeholder="Mehmet Yılmaz" @bind="_customer.FullName" />
                        @if (_submitted && string.IsNullOrWhiteSpace(_customer.FullName))
                        {
                            <div class="text-danger fs-12 mt-1">Ad soyad zorunludur.</div>
                        }
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">Telefon <span class="text-danger">*</span></label>
                        <input class="form-control" placeholder="0532 111 2233" type="tel" @bind="_customer.Phone" />
                        @if (_submitted && string.IsNullOrWhiteSpace(_customer.Phone))
                        {
                            <div class="text-danger fs-12 mt-1">Telefon zorunludur.</div>
                        }
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">E-posta</label>
                        <input class="form-control" placeholder="ornek@email.com" type="email" @bind="_customer.Email" />
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">Firma Adı</label>
                        <input class="form-control" placeholder="Opsiyonel" @bind="_customer.CompanyName" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Adres</label>
                        <textarea class="form-control" rows="2" placeholder="Müşteri adresi (opsiyonel)" @bind="_customer.Address"></textarea>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">Vergi Numarası</label>
                        <input class="form-control" placeholder="Kurumsal fatura için" @bind="_customer.TaxNumber" />
                    </div>
                </div>

                <div class="d-flex gap-2 justify-content-end">
                    <a href="/customers" class="btn btn-light-sm">İptal</a>
                    <button class="btn btn-accent" @onclick="HandleSubmit">
                        <i class="bi bi-check-lg me-1"></i> Müşteriyi Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-5">
        <div class="card">
            <div class="card-body text-center py-5">
                <div class="customer-avatar mx-auto mb-3" style="width:64px;height:64px;font-size:26px">
                    @(string.IsNullOrEmpty(_customer.FullName) ? "?" : _customer.FullName.Substring(0,1).ToUpper())
                </div>
                <div class="fw-700 fs-16 mb-1">
                    @(string.IsNullOrEmpty(_customer.FullName) ? "Yeni Müşteri" : _customer.FullName)
                </div>
                @if (!string.IsNullOrEmpty(_customer.Phone))
                {
                    <div class="text-muted fs-13">@_customer.Phone</div>
                }
                @if (!string.IsNullOrEmpty(_customer.Email))
                {
                    <div class="text-muted fs-13">@_customer.Email</div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private Customer _customer = new();
    private bool _submitted = false;

    private async Task HandleSubmit()
    {
        _submitted = true;
        if (string.IsNullOrWhiteSpace(_customer.FullName) || string.IsNullOrWhiteSpace(_customer.Phone))
            return;

        await Store.AddCustomerAsync(_customer);
        Nav.NavigateTo("/customers");
    }
}
