@inject NavigationManager NavigationManager

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    @{
                        var returnUrl = Uri.EscapeDataString(new Uri(NavigationManager.Uri).PathAndQuery);
                        NavigationManager.NavigateTo($"/giris?ReturnUrl={returnUrl}", forceLoad: true);
                    }
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Sayfa Bulunamadı</PageTitle>
            <LayoutView Layout="@typeof(PublicLayout)">
                <div style="text-align:center;padding:140px 20px 80px;">
                    <div style="font-size:80px;margin-bottom:16px;">🔍</div>
                    <h1 style="margin:0 0 8px;font-size:32px;font-weight:800;">404 — Sayfa Bulunamadı</h1>
                    <p style="color:#6b7280;margin-bottom:32px;">Aradığınız sayfa mevcut değil.</p>
                    <a href="/" style="background:#0066CC;color:#fff;padding:12px 28px;border-radius:8px;text-decoration:none;font-weight:600;">Ana Sayfaya Dön</a>
                </div>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
