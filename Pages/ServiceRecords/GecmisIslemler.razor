@page "/gecmis-islemler"
@attribute [Authorize]
@inject JsonDataStore Store
@inject NavigationManager Nav

<PageTitle>Geçmiş İşlemler — Ascar Servis</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Geçmiş İşlemler</h1>
        <p class="page-subtitle">Tamamlanan ve teslim edilen tüm servis kayıtları</p>
    </div>
</div>

<!-- KPI Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-xl-3">
        <div class="stat-card si-green">
            <div class="stat-card-top">
                <div>
                    <div class="stat-card-value">@_all.Count</div>
                    <div class="stat-card-label">Toplam Tamamlanan</div>
                </div>
                <div class="stat-card-icon"><i class="bi bi-check-circle-fill"></i></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card si-blue">
            <div class="stat-card-top">
                <div>
                    <div class="stat-card-value" style="font-size:20px">@_all.Where(r => r.FinalCost.HasValue).Sum(r => r.FinalCost!.Value).ToString("N0") ₺</div>
                    <div class="stat-card-label">Toplam Ciro</div>
                </div>
                <div class="stat-card-icon"><i class="bi bi-wallet2"></i></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card si-teal">
            <div class="stat-card-top">
                <div>
                    <div class="stat-card-value">@(_avgDays > 0 ? _avgDays.ToString("F1") : "—")</div>
                    <div class="stat-card-label">Ort. Servis Süresi (Gün)</div>
                </div>
                <div class="stat-card-icon"><i class="bi bi-clock-history"></i></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card si-slate">
            <div class="stat-card-top">
                <div>
                    <div class="stat-card-value">@_filtered.Count</div>
                    <div class="stat-card-label">Filtredeki Kayıt</div>
                </div>
                <div class="stat-card-icon"><i class="bi bi-funnel-fill"></i></div>
            </div>
        </div>
    </div>
</div>

<!-- Filter Card -->
<div class="card mb-3">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-12 col-sm-6 col-lg-3">
                <label class="form-label">Ara (Plaka / Müşteri / Kayıt No)</label>
                <div class="search-box">
                    <i class="bi bi-search"></i>
                    <input class="form-control" placeholder="Arama..." @bind="_search" @bind:event="oninput" />
                </div>
            </div>
            <div class="col-6 col-sm-3 col-lg-2">
                <label class="form-label">Giriş Başlangıç</label>
                <input type="date" class="form-control" @bind="_dateFrom" />
            </div>
            <div class="col-6 col-sm-3 col-lg-2">
                <label class="form-label">Giriş Bitiş</label>
                <input type="date" class="form-control" @bind="_dateTo" />
            </div>
            <div class="col-6 col-sm-6 col-lg-2">
                <label class="form-label">Teknisyen</label>
                <select class="form-select" @bind="_techFilter">
                    <option value="">Tümü</option>
                    @foreach (var t in _technicians)
                    {
                        <option value="@t">@t</option>
                    }
                </select>
            </div>
            <div class="col-6 col-sm-6 col-lg-2">
                <label class="form-label">Durum</label>
                <select class="form-select" @bind="_statusFilter">
                    <option value="">Tümü</option>
                    <option value="Completed">Tamamlandı</option>
                    <option value="Delivered">Teslim Edildi</option>
                </select>
            </div>
            <div class="col-12 col-lg-1 d-flex align-items-end">
                <button class="btn btn-secondary btn-sm w-100" @onclick="ResetFilters" title="Filtreleri Temizle">
                    <i class="bi bi-x-circle me-1"></i> Temizle
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Table -->
<div class="card">
    <div class="table-responsive">
        @if (_filtered.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-state-icon"><i class="bi bi-clock-history"></i></div>
                <div class="empty-state-title">Kayıt Bulunamadı</div>
                <div class="empty-state-text">Filtre kriterlerinize uygun tamamlanmış kayıt yok.</div>
            </div>
        }
        else
        {
            <table class="table-ascar table-clickable">
                <thead>
                    <tr>
                        <th>Kayıt No</th>
                        <th>Araç / Plaka</th>
                        <th>Müşteri</th>
                        <th>Giriş Tarihi</th>
                        <th>Çıkış Tarihi</th>
                        <th>Süre</th>
                        <th>Teknisyen</th>
                        <th>Kesin Maliyet</th>
                        <th>Durum</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _filtered)
                    {
                        <tr @onclick="@(() => Nav.NavigateTo($"/service-records/{r.Id}"))">
                            <td>
                                <span class="record-number">@r.RecordNumber</span>
                                @if (r.HasInsurance)
                                {
                                    <span class="badge-status ms-1" style="background:#d1fae5;color:#065f46;font-size:10px;">
                                        <i class="bi bi-shield-check"></i>
                                    </span>
                                }
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="vehicle-icon-wrap" style="width:32px;height:32px;font-size:14px">
                                        <i class="bi bi-car-front"></i>
                                    </div>
                                    <div>
                                        <div class="fw-600">@r.Vehicle?.Brand @r.Vehicle?.Model</div>
                                        <span class="plate-badge" style="font-size:11px">@r.Vehicle?.Plate</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="customer-avatar" style="width:30px;height:30px;font-size:12px">
                                        @(r.Vehicle?.Customer?.FullName?.Substring(0, 1) ?? "?")
                                    </div>
                                    <div>
                                        <div class="fw-600 fs-13">@r.Vehicle?.Customer?.FullName</div>
                                        <div class="fs-12 text-muted">@r.Vehicle?.Customer?.Phone</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="fw-600">@r.EntryDate.ToString("dd.MM.yyyy")</div>
                            </td>
                            <td>
                                @if (r.ExitDate.HasValue)
                                {
                                    <div class="fw-600">@r.ExitDate.Value.ToString("dd.MM.yyyy")</div>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                @if (r.ExitDate.HasValue)
                                {
                                    var days = (int)(r.ExitDate.Value - r.EntryDate).TotalDays;
                                    <span class="tag"><i class="bi bi-clock me-1"></i>@days gün</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(r.AssignedTechnician))
                                {
                                    <span class="fw-600">@r.AssignedTechnician</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                @if (r.FinalCost.HasValue)
                                {
                                    <span class="fw-700 text-success">@r.FinalCost.Value.ToString("N0") ₺</span>
                                }
                                else if (r.EstimatedCost > 0)
                                {
                                    <span class="text-muted fs-12">~@r.EstimatedCost.ToString("N0") ₺</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>@StatusBadge(r.Status)</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
    <div class="px-4 py-2 border-top d-flex justify-content-between align-items-center" style="border-color:#f3f4f6 !important">
        <span class="fs-12 text-muted">@_filtered.Count kayıt gösteriliyor</span>
        @if (_filtered.Any(r => r.FinalCost.HasValue))
        {
            <span class="fs-12 fw-700">
                Filtre Toplamı: @_filtered.Where(r => r.FinalCost.HasValue).Sum(r => r.FinalCost!.Value).ToString("N0") ₺
            </span>
        }
    </div>
</div>

@code {
    private List<ServiceRecord> _all = new();
    private string _search = "";
    private DateTime? _dateFrom;
    private DateTime? _dateTo;
    private string _techFilter = "";
    private string _statusFilter = "";
    private double _avgDays;

    private List<string> _technicians => _all
        .Where(r => !string.IsNullOrEmpty(r.AssignedTechnician))
        .Select(r => r.AssignedTechnician!)
        .Distinct()
        .OrderBy(t => t)
        .ToList();

    private List<ServiceRecord> _filtered => _all
        .Where(r => string.IsNullOrEmpty(_search) ||
                    r.RecordNumber.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                    (r.Vehicle?.Plate?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (r.Vehicle?.Customer?.FullName?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (r.Vehicle?.Brand?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (r.Vehicle?.Model?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(r => _dateFrom == null || r.EntryDate.Date >= _dateFrom.Value.Date)
        .Where(r => _dateTo == null || r.EntryDate.Date <= _dateTo.Value.Date)
        .Where(r => string.IsNullOrEmpty(_techFilter) || r.AssignedTechnician == _techFilter)
        .Where(r => string.IsNullOrEmpty(_statusFilter) ||
                    (_statusFilter == "Completed" && r.Status == ServiceStatus.Completed) ||
                    (_statusFilter == "Delivered" && r.Status == ServiceStatus.Delivered))
        .OrderByDescending(r => r.ExitDate ?? r.EntryDate)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        var all = await Store.GetServiceRecordsAsync();
        _all = all
            .Where(r => r.Status == ServiceStatus.Completed || r.Status == ServiceStatus.Delivered)
            .ToList();

        var withExit = _all.Where(r => r.ExitDate.HasValue).ToList();
        _avgDays = withExit.Any() ? withExit.Average(r => (r.ExitDate!.Value - r.EntryDate).TotalDays) : 0;
    }

    private void ResetFilters()
    {
        _search = "";
        _dateFrom = null;
        _dateTo = null;
        _techFilter = "";
        _statusFilter = "";
    }

    private RenderFragment StatusBadge(ServiceStatus s) => s switch
    {
        ServiceStatus.Completed => @<span class="badge-status badge-completed">Tamamlandı</span>,
        ServiceStatus.Delivered => @<span class="badge-status badge-delivered">Teslim Edildi</span>,
        _ => @<span class="badge-status badge-delivered">—</span>
    };
}
