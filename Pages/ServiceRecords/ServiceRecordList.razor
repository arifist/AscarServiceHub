@page "/service-records"
@attribute [Authorize]
@inject JsonDataStore Store
@inject NavigationManager Nav

<PageTitle>Servis Kayıtları — Ascar Servis</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Servis Kayıtları</h1>
        <p class="page-subtitle">Tüm araç servis ve onarım kayıtları</p>
    </div>
    <a href="/service-records/create" class="btn btn-accent">
        <i class="bi bi-plus-lg"></i> Yeni Kayıt
    </a>
</div>

<div class="card">
    <!-- Filter Bar -->
    <div class="filter-bar">
        <div class="search-box">
            <i class="bi bi-search"></i>
            <input class="form-control" placeholder="Plaka, müşteri veya kayıt no ara..." @bind="_search" @bind:event="oninput" />
        </div>

        <div class="status-tabs">
            <button class="status-tab @(SelectedFilter == null ? "active-tab" : "")" @onclick="@(() => SelectedFilter = null)">
                Tümü <span class="tab-count">@_all.Count</span>
            </button>
            <button class="status-tab @(SelectedFilter == ServiceStatus.Waiting ? "active-tab" : "")" @onclick="@(() => SelectedFilter = ServiceStatus.Waiting)">
                Bekliyor <span class="tab-count">@_all.Count(r => r.Status == ServiceStatus.Waiting)</span>
            </button>
            <button class="status-tab @(SelectedFilter == ServiceStatus.Diagnosing ? "active-tab" : "")" @onclick="@(() => SelectedFilter = ServiceStatus.Diagnosing)">
                İnceleniyor <span class="tab-count">@_all.Count(r => r.Status == ServiceStatus.Diagnosing)</span>
            </button>
            <button class="status-tab @(SelectedFilter == ServiceStatus.InProgress ? "active-tab" : "")" @onclick="@(() => SelectedFilter = ServiceStatus.InProgress)">
                Onarımda <span class="tab-count">@_all.Count(r => r.Status == ServiceStatus.InProgress)</span>
            </button>
            <button class="status-tab @(SelectedFilter == ServiceStatus.Completed ? "active-tab" : "")" @onclick="@(() => SelectedFilter = ServiceStatus.Completed)">
                Tamamlandı <span class="tab-count">@_all.Count(r => r.Status == ServiceStatus.Completed)</span>
            </button>
            <button class="status-tab @(SelectedFilter == ServiceStatus.Delivered ? "active-tab" : "")" @onclick="@(() => SelectedFilter = ServiceStatus.Delivered)">
                Teslim <span class="tab-count">@_all.Count(r => r.Status == ServiceStatus.Delivered)</span>
            </button>
        </div>
    </div>

    <!-- Table -->
    <div class="table-responsive">
        @if (_filtered.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-state-icon"><i class="bi bi-clipboard2-x"></i></div>
                <div class="empty-state-title">Kayıt Bulunamadı</div>
                <div class="empty-state-text">Arama kriterlerinize uygun kayıt yok.</div>
            </div>
        }
        else
        {
            <table class="table-ascar table-clickable">
                <thead>
                    <tr>
                        <th>Kayıt No</th>
                        <th>Araç</th>
                        <th>Müşteri</th>
                        <th>Giriş Tarihi</th>
                        <th>Teknisyen</th>
                        <th>Tahmini Maliyet</th>
                        <th>Durum</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _filtered)
                    {
                        <tr @onclick="@(() => Nav.NavigateTo($"/service-records/{r.Id}"))">
                            <td>
                                <span class="record-number">@r.RecordNumber</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="vehicle-icon-wrap" style="width:36px;height:36px">
                                        <i class="bi bi-car-front"></i>
                                    </div>
                                    <div>
                                        <div class="fw-600">@r.Vehicle?.Brand @r.Vehicle?.Model</div>
                                        <span class="plate-badge">@r.Vehicle?.Plate</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="customer-avatar">@(r.Vehicle?.Customer?.FullName?.Substring(0,1) ?? "?")</div>
                                    <div>
                                        <div class="fw-600">@r.Vehicle?.Customer?.FullName</div>
                                        <div class="fs-12 text-muted">@r.Vehicle?.Customer?.Phone</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="fw-600">@r.EntryDate.ToString("dd.MM.yyyy")</div>
                                <div class="fs-12 text-muted">@r.EntryDate.ToString("HH:mm")</div>
                            </td>
                            <td>
                                @if (string.IsNullOrEmpty(r.AssignedTechnician))
                                {
                                    <span class="text-muted fs-12">—</span>
                                }
                                else
                                {
                                    <span class="fw-600">@r.AssignedTechnician</span>
                                }
                            </td>
                            <td>
                                @if (r.EstimatedCost > 0)
                                {
                                    <span class="fw-600">@r.EstimatedCost.ToString("N0") ₺</span>
                                }
                                else
                                {
                                    <span class="text-muted fs-12">Belirsiz</span>
                                }
                            </td>
                            <td>@StatusBadge(r.Status)</td>
                            <td onclick="event.stopPropagation()">
                                <div class="d-flex gap-1">
                                    <a href="/service-records/@r.Id" class="btn btn-icon btn-light-sm" title="Detay">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
    <div class="px-4 py-2 border-top d-flex justify-content-between align-items-center" style="border-color:#f3f4f6 !important">
        <span class="fs-12 text-muted">@_filtered.Count kayıt gösteriliyor</span>
    </div>
</div>

@code {
    private List<ServiceRecord> _all = new();
    private string _search = "";
    private ServiceStatus? _selectedFilter;

    private ServiceStatus? SelectedFilter
    {
        get => _selectedFilter;
        set { _selectedFilter = value; }
    }

    private List<ServiceRecord> _filtered => _all
        .Where(r => SelectedFilter == null || r.Status == SelectedFilter)
        .Where(r => string.IsNullOrWhiteSpace(_search) ||
                    r.RecordNumber.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                    (r.Vehicle?.Plate?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (r.Vehicle?.Customer?.FullName?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (r.Vehicle?.Brand?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        _all = await Store.GetServiceRecordsAsync();
    }

    private RenderFragment StatusBadge(ServiceStatus s) => s switch
    {
        ServiceStatus.Waiting    => @<span class="badge-status badge-waiting">Bekliyor</span>,
        ServiceStatus.Diagnosing => @<span class="badge-status badge-diagnosing">İnceleniyor</span>,
        ServiceStatus.InProgress => @<span class="badge-status badge-inprogress">Onarımda</span>,
        ServiceStatus.Completed  => @<span class="badge-status badge-completed">Tamamlandı</span>,
        ServiceStatus.Delivered  => @<span class="badge-status badge-delivered">Teslim Edildi</span>,
        _                        => @<span class="badge-status badge-delivered">-</span>
    };
}
