@page "/hizmetler"
@layout PublicLayout

<PageTitle>Hizmetler — Ascar Oto Kaporta & Boya</PageTitle>

<!-- ─── HERO ─────────────────────────────────────────────────── -->
<section style="padding:140px 0 80px; background:var(--pub-dark); position:relative; overflow:hidden;">
    <div style="position:absolute; inset:0; background-image:url('/images/detay_temizlik.jpg'); background-size:cover; background-position:center; opacity:0.2;"></div>
    <div style="position:absolute; inset:0; background:linear-gradient(180deg, rgba(10,15,30,0.6) 0%, rgba(10,15,30,0.95) 100%);"></div>
    <!-- Decorative circles -->
    <div style="position:absolute; width:500px; height:500px; border-radius:50%; border:1px solid rgba(255,255,255,0.04); top:-200px; right:-200px;"></div>
    <div style="position:absolute; width:300px; height:300px; border-radius:50%; border:1px solid rgba(255,255,255,0.04); bottom:-100px; left:-100px;"></div>

    <div class="container-xl text-center" style="position:relative;">
        <div class="section-tag" style="background:rgba(255,255,255,0.08); color:rgba(255,255,255,0.8); border:1px solid rgba(255,255,255,0.12); display:inline-flex; margin:0 auto 20px;">
            <i class="bi bi-tools"></i> Hizmetlerimiz
        </div>
        <h1 style="font-size:clamp(36px,5vw,60px); font-weight:900; color:#fff; margin-bottom:20px; line-height:1.1;">
            Uzmanlık Gerektiren Her İşe<br/><span style="color:#60a5fa;">Profesyonel Çözüm</span>
        </h1>
        <p style="font-size:18px; color:rgba(255,255,255,0.6); max-width:540px; margin:0 auto;">
            Son teknoloji ekipman ve deneyimli kadromuzla kaporta, boya ve hasar onarımında kapsamlı hizmet.
        </p>

        <!-- Service Quick Links -->
        <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap; margin-top:48px;">
            @foreach (var link in new[] { ("Kaporta", "#kaporta"), ("Oto Boya", "#boya"), ("PDR", "#pdr"), ("Sigorta", "#sigorta"), ("Fiyatlar", "#fiyatlar") })
            {
                <a href="@link.Item2"
                   style="background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.12); color:rgba(255,255,255,0.8); padding:10px 20px; border-radius:99px; font-size:13px; font-weight:600; text-decoration:none; transition:all 0.2s;"
                   onmouseover="this.style.background='var(--pub-blue)';this.style.color='#fff';"
                   onmouseout="this.style.background='rgba(255,255,255,0.08)';this.style.color='rgba(255,255,255,0.8)';">
                    @link.Item1
                </a>
            }
        </div>
    </div>
</section>

<!-- ─── KAPORTA ────────────────────────────────────────────────── -->
<section id="kaporta" style="padding:100px 0; background:#fff;">
    <div class="container-xl">
        <div class="row align-items-center g-5">
            <div class="col-12 col-lg-6">
                <div class="section-tag"><i class="bi bi-car-front"></i> Kaporta Tamiri</div>
                <h2 class="section-title">Çarpma ve Hasar Sonrası<br/><span>Fabrika Kalitesi</span></h2>
                <p style="font-size:16px; color:var(--pub-gray); line-height:1.9; margin-bottom:28px;">
                    Küçük göçüklerden büyük şasi hasarlarına kadar her türlü kaporta onarımını OEM standartlarında gerçekleştiriyoruz. Orijinal ölçümlere dönüş ve yapısal bütünlük testi dahil.
                </p>
                <div class="row g-3 mb-28">
                    @foreach (var f in _kapFeat)
                    {
                        <div class="col-12 col-sm-6">
                            <div style="display:flex; gap:10px; align-items:flex-start;">
                                <i class="bi bi-check-circle-fill" style="color:var(--pub-blue); font-size:16px; margin-top:2px; flex-shrink:0;"></i>
                                <span style="font-size:14px; color:var(--pub-gray);">@f</span>
                            </div>
                        </div>
                    }
                </div>
                <a href="/iletisim" class="pub-btn pub-btn-primary" style="margin-top:24px;">
                    Fiyat Teklifi Al <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            <div class="col-12 col-lg-6">
                <div style="border-radius:24px; overflow:hidden; height:420px; box-shadow:0 24px 64px rgba(0,0,0,0.12); position:relative;">
                    <img src="/images/kaporta.jpg"
                         alt="Kaporta Tamiri" style="width:100%; height:100%; object-fit:cover;" />
                    <div style="position:absolute; inset:0; background:linear-gradient(to top, rgba(10,15,30,0.5) 0%, transparent 50%);"></div>
                    <div style="position:absolute; bottom:20px; left:20px; color:#fff;">
                        <div style="font-size:13px; font-weight:700; opacity:0.9;">Kaporta Onarım</div>
                        <div style="font-size:11px; opacity:0.6;">Her hasar türü için uzman çözüm</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ─── OTO BOYA ───────────────────────────────────────────────── -->
<section id="boya" style="padding:100px 0; background:#f8faff;">
    <div class="container-xl">
        <div class="row align-items-center g-5">
            <div class="col-12 col-lg-6 order-lg-2">
                <div class="section-tag"><i class="bi bi-droplet-fill"></i> Oto Boya</div>
                <h2 class="section-title">Renk Eşleştirmede<br/><span>Kusursuz Sonuç</span></h2>
                <p style="font-size:16px; color:var(--pub-gray); line-height:1.9; margin-bottom:28px;">
                    Spektrofotometre ile tam renk eşleştirme, çevre dostu su bazlı boyalar ve otomatik boya kabini teknolojimizle her araç için fabrika çıkışı sonuç garanti ediyoruz.
                </p>
                <div class="row g-3 mb-28">
                    @foreach (var f in _boyaFeat)
                    {
                        <div class="col-12 col-sm-6">
                            <div style="display:flex; gap:10px; align-items:flex-start;">
                                <i class="bi bi-check-circle-fill" style="color:var(--pub-blue); font-size:16px; margin-top:2px; flex-shrink:0;"></i>
                                <span style="font-size:14px; color:var(--pub-gray);">@f</span>
                            </div>
                        </div>
                    }
                </div>
                <a href="/iletisim" class="pub-btn pub-btn-primary" style="margin-top:24px;">
                    Fiyat Teklifi Al <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            <div class="col-12 col-lg-6 order-lg-1">
                <div style="border-radius:24px; overflow:hidden; height:420px; box-shadow:0 24px 64px rgba(0,0,0,0.12); position:relative;">
                    <img src="/images/boya_kabini.jpg"
                         alt="Oto Boya" style="width:100%; height:100%; object-fit:cover;" />
                    <div style="position:absolute; inset:0; background:linear-gradient(to top, rgba(10,15,30,0.5) 0%, transparent 50%);"></div>
                    <div style="position:absolute; bottom:20px; left:20px; color:#fff;">
                        <div style="font-size:13px; font-weight:700; opacity:0.9;">Oto Boya</div>
                        <div style="font-size:11px; opacity:0.6;">Spektrofotometre ile tam renk eşleştirme</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ─── PDR ────────────────────────────────────────────────────── -->
<section id="pdr" style="padding:100px 0; background:#fff;">
    <div class="container-xl">
        <div class="row align-items-center g-5">
            <div class="col-12 col-lg-6">
                <div class="section-tag"><i class="bi bi-magnet"></i> Boyasız Göçük (PDR)</div>
                <h2 class="section-title">Boya Bozmadan<br/><span>Mükemmel Sonuç</span></h2>
                <p style="font-size:16px; color:var(--pub-gray); line-height:1.9; margin-bottom:28px;">
                    Paintless Dent Repair teknolojisi ile dolu hasarı, park ezikleri ve kapı göçüklerini aracın özgün boyasına dokunmadan gideriyoruz. Hem daha hızlı hem daha ekonomik.
                </p>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:28px;">
                    @foreach (var a in _pdrAdvantages)
                    {
                        <div style="background:var(--pub-blue-light); border-radius:12px; padding:16px; text-align:center;">
                            <div style="font-size:24px; color:var(--pub-blue); margin-bottom:8px;"><i class="bi @a.Icon"></i></div>
                            <div style="font-size:13px; font-weight:700; color:var(--pub-dark2); margin-bottom:4px;">@a.Title</div>
                            <div style="font-size:12px; color:var(--pub-gray);">@a.Text</div>
                        </div>
                    }
                </div>
                <a href="/iletisim" class="pub-btn pub-btn-primary">
                    Ücretsiz Değerlendirme <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            <div class="col-12 col-lg-6">
                <div style="border-radius:24px; overflow:hidden; height:420px; box-shadow:0 24px 64px rgba(0,0,0,0.12); position:relative;">
                    <img src="/images/kaporta_onarim.jpg"
                         alt="PDR Boyasız Göçük Düzeltme" style="width:100%; height:100%; object-fit:cover;" />
                    <div style="position:absolute; inset:0; background:linear-gradient(to top, rgba(10,15,30,0.5) 0%, transparent 50%);"></div>
                    <div style="position:absolute; bottom:20px; left:20px; color:#fff;">
                        <div style="font-size:13px; font-weight:700; opacity:0.9;">PDR Teknolojisi</div>
                        <div style="font-size:11px; opacity:0.6;">Boyasız ve hızlı göçük düzeltme</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ─── SİGORTA ────────────────────────────────────────────────── -->
<section id="sigorta" style="padding:80px 0; background:var(--pub-dark2); position:relative; overflow:hidden;">
    <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 70% 50%, rgba(0,102,204,0.2) 0%, transparent 60%);"></div>
    <div class="container-xl" style="position:relative;">
        <div class="row align-items-center g-5">
            <div class="col-12 col-lg-5">
                <div class="section-tag" style="background:rgba(255,255,255,0.08); color:rgba(255,255,255,0.8); border:1px solid rgba(255,255,255,0.12);">
                    <i class="bi bi-shield-check"></i> Sigorta İşlemleri
                </div>
                <h2 class="section-title section-title-white">Sigorta Sürecini<br/><span style="color:#60a5fa;">Biz Yönetiyoruz</span></h2>
                <p style="font-size:16px; color:rgba(255,255,255,0.6); line-height:1.9; margin-bottom:28px;">
                    50'den fazla sigorta şirketiyle anlaşmalı servisimizde; hasar tespiti, dosya açılışı, eksper görüşmesi ve fatura sürecini sizin adınıza takip ediyoruz.
                </p>
                <a href="/iletisim" class="pub-btn pub-btn-primary">
                    Sigorta Danışmanlığı <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            <div class="col-12 col-lg-7">
                <div class="row g-3">
                    @foreach (var s in _insuranceSteps)
                    {
                        <div class="col-12 col-sm-6">
                            <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:16px; padding:20px 24px; display:flex; gap:16px; align-items:flex-start;">
                                <div style="width:36px; height:36px; border-radius:10px; background:rgba(0,102,204,0.3); color:#60a5fa; display:flex; align-items:center; justify-content:center; font-size:16px; flex-shrink:0;">
                                    @s.Step
                                </div>
                                <div>
                                    <div style="font-weight:700; font-size:14px; color:#fff; margin-bottom:4px;">@s.Title</div>
                                    <div style="font-size:13px; color:rgba(255,255,255,0.5); line-height:1.6;">@s.Text</div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ─── FİYATLAR ──────────────────────────────────────────────── -->
<section id="fiyatlar" style="padding:100px 0; background:#f8faff;">
    <div class="container-xl">
        <div class="text-center mb-5">
            <div class="section-tag"><i class="bi bi-tag"></i> Fiyatlandırma</div>
            <h2 class="section-title">Şeffaf ve <span>Rekabetçi Fiyatlar</span></h2>
            <p class="section-lead mx-auto" style="text-align:center; max-width:500px;">Tüm fiyatlarımız KDV dahildir. Ücretsiz hasar tespiti için bizi arayın.</p>
        </div>

        <div class="row g-4 justify-content-center">
            @foreach (var p in _plans)
            {
                <div class="col-12 col-md-4">
                    <div style="background:@(p.Featured ? "var(--pub-blue)" : "#fff"); border-radius:24px; padding:40px 32px; border:@(p.Featured ? "none" : "1px solid var(--pub-border)"); box-shadow:@(p.Featured ? "0 24px 64px rgba(0,102,204,0.3)" : "0 4px 24px rgba(0,0,0,0.06)"); position:relative; overflow:hidden; height:100%; display:flex; flex-direction:column; transform:@(p.Featured ? "translateY(-8px)" : "none");">
                        @if (p.Featured)
                        {
                            <div style="position:absolute; top:20px; right:20px; background:rgba(255,255,255,0.2); color:#fff; font-size:11px; font-weight:700; padding:4px 12px; border-radius:99px; text-transform:uppercase; letter-spacing:1px;">Popüler</div>
                        }
                        <div style="font-size:14px; font-weight:700; color:@(p.Featured ? "rgba(255,255,255,0.8)" : "var(--pub-gray)"); text-transform:uppercase; letter-spacing:1px; margin-bottom:16px;">@p.Name</div>
                        <div style="margin-bottom:8px;">
                            <span style="font-size:40px; font-weight:900; color:@(p.Featured ? "#fff" : "var(--pub-dark2)");">@p.Price</span>
                            <span style="font-size:14px; color:@(p.Featured ? "rgba(255,255,255,0.6)" : "var(--pub-gray)"); margin-left:4px;">@p.Unit</span>
                        </div>
                        <p style="font-size:14px; color:@(p.Featured ? "rgba(255,255,255,0.7)" : "var(--pub-gray)"); line-height:1.7; margin-bottom:28px;">@p.Description</p>
                        <div style="flex:1;">
                            @foreach (var f in p.Features)
                            {
                                <div style="display:flex; gap:10px; align-items:center; margin-bottom:12px;">
                                    <i class="bi bi-check-circle-fill" style="color:@(p.Featured ? "rgba(255,255,255,0.8)" : "var(--pub-blue)"); font-size:15px; flex-shrink:0;"></i>
                                    <span style="font-size:14px; color:@(p.Featured ? "rgba(255,255,255,0.85)" : "var(--pub-gray)");">@f</span>
                                </div>
                            }
                        </div>
                        <a href="/iletisim" class="pub-btn" style="margin-top:28px; width:100%; justify-content:center; background:@(p.Featured ? "#fff" : "var(--pub-blue)"); color:@(p.Featured ? "var(--pub-blue)" : "#fff");">
                            Teklif Al <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
            }
        </div>

        <p class="text-center mt-4" style="font-size:13px; color:var(--pub-gray);">
            * Fiyatlar araç modeli ve hasar durumuna göre değişiklik gösterebilir. Kesin fiyat için ücretsiz hasar tespiti yapılmaktadır.
        </p>
    </div>
</section>

@code {
    private readonly string[] _kapFeat =
    [
        "Şasi düzeltme ve ölçüm",
        "Panel değişimi",
        "Alüminyum ve çelik onarım",
        "Kaynak işlemleri",
        "Yapısal bütünlük testi",
        "2 yıl işçilik garantisi",
    ];

    private readonly string[] _boyaFeat =
    [
        "Tam boya yenileme",
        "Spot boya onarımı",
        "Seramik kaplama",
        "Renk eşleştirme teknolojisi",
        "Su bazlı çevre dostu boya",
        "Yüzey cilası ve koruma",
    ];

    private record PdrAdvantage(string Icon, string Title, string Text);
    private readonly PdrAdvantage[] _pdrAdvantages =
    [
        new("bi-clock", "Hızlı", "1-3 iş günü teslim"),
        new("bi-cash-coin", "Ekonomik", "Boyaya göre %40 tasarruf"),
        new("bi-shield-check", "Güvenli", "Orijinal boya korunur"),
        new("bi-star-fill", "Kaliteli", "Sertifikalı PDR ustası"),
    ];

    private record InsuranceStep(string Step, string Title, string Text);
    private readonly InsuranceStep[] _insuranceSteps =
    [
        new("1", "Hasar Tespiti", "Aracınızı getirin, uzmanımız ücretsiz hasar tespiti yapar."),
        new("2", "Dosya Açılışı", "Sigorta şirketiyle iletişime geçerek dosyanızı açıyoruz."),
        new("3", "Eksper Süreci", "Eksper görüşmelerini ve ek hasar tespitlerini yönetiyoruz."),
        new("4", "Onarım & Teslim", "Onaylanan işlemler tamamlanır, aracınız teslim edilir."),
    ];

    private record Plan(string Name, string Price, string Unit, string Description, string[] Features, bool Featured);
    private readonly Plan[] _plans =
    [
        new("Temel", "₺2.500'den", "başlayan", "Spot boya, küçük göçük ve PDR işlemleri için uygun fiyatlı paket.", ["Spot boya (1 panel)", "PDR (3 göçüğe kadar)", "Yüzey temizliği", "1 yıl garanti"], false),
        new("Standart", "₺6.000'den", "başlayan", "Orta ölçekli kaporta ve tam panel boya işlemleri için kapsamlı paket.", ["3 panele kadar kaporta", "Tam panel boya", "Renk eşleştirme", "Seramik kaplama", "2 yıl garanti"], true),
        new("Sigorta", "Sigorta", "karşılar", "Tam kapsamlı hasar onarımı. Sigorta şirketinizle tüm koordinasyonu biz yapıyoruz.", ["Tam hasar tespiti", "Sigorta dosya takibi", "Tüm kaporta ve boya", "Yedek araç desteği", "2 yıl garanti"], false),
    ];
}
