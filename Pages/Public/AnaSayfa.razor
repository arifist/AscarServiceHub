    private async Task PlateKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") GoToSearch();
        await Task.CompletedTask;
    }

    private void GoToSearch()
    {
        if (!string.IsNullOrWhiteSpace(_plate))
            Nav.NavigateTo($"/arac-sorgula?plaka={Uri.EscapeDataString(_plate.Trim().ToUpperInvariant())}");
        else
            Nav.NavigateTo("/arac-sorgula");
    }

    private async Task CtaKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") GoToSearchCta();
        await Task.CompletedTask;
    }

    private void GoToSearchCta()
    {
        if (!string.IsNullOrWhiteSpace(_plateCta))
            Nav.NavigateTo($"/arac-sorgula?plaka={Uri.EscapeDataString(_plateCta.Trim().ToUpperInvariant())}");
        else
            Nav.NavigateTo("/arac-sorgula");
    }
